{
  "version": 3,
  "framework": {
    "name": "nitro",
    "version": "3.0.260603-beta"
  },
  "overrides": {},
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/_server/(?:.*))",
      "dest": "/__server"
    },
    {
      "src": "/(.*)",
      "dest": "/__server"
    }
  ]
}